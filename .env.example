# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.

# ---------------------------------------------------------------------------
# Optional proxy configuration (leave blank to disable proxy)
# ---------------------------------------------------------------------------
CF_PROXY_HOST=
CF_PROXY_PORT=
CF_PROXY_USERNAME=
CF_PROXY_PASSWORD=
CF_PROXY_PROTOCOL=http

# ---------------------------------------------------------------------------
# Bypass engine settings (all optional — defaults shown)
# ---------------------------------------------------------------------------
CF_MAX_RETRIES=3
CF_TIMEOUT=30
CF_HEADLESS=true
CF_SESSION_DIR=.cf_sessions
CF_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Integration test target (used only by tests/test_integration.py)
# ---------------------------------------------------------------------------
# nowsecure.nl is a public CF challenge test page — safe to use as-is.
CF_TEST_URL=https://nowsecure.nl
